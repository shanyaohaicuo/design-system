{
  "$schema": "https://design-tokens.org/schema.json",
  "$metadata": {
    "version": "1.0.0",
    "name": "山肴海错设计系统"
  },
  "color": {
    "primary": {
      "light": "#1A1A1A",
      "dark": "#E0E0E0",
      "type": "color",
      "description": "主文字、主要按钮背景"
    },
    "surface": {
      "light": "#FFFFFF",
      "dark": "#1A1A1A",
      "type": "color",
      "description": "底层背景"
    },
    "surface-elevated": {
      "light": "#F5F5F5",
      "dark": "#262626",
      "type": "color",
      "description": "卡片、弹窗背景"
    },
    "text-secondary": {
      "light": "#666666",
      "dark": "#999999",
      "type": "color",
      "description": "辅助说明文字"
    },
    "border": {
      "light": "#E5E5E5",
      "dark": "#333333",
      "type": "color",
      "description": "边框、分割线"
    },
    "accent": {
      "light": "#7A5C3B",
      "dark": "#A68B6E",
      "type": "color",
      "description": "唯一强调色，仅用于关键行动点"
    },
    "disabled": {
      "light": "#CCCCCC",
      "dark": "#555555",
      "type": "color",
      "description": "禁用状态"
    }
  },
  "spacing": {
    "base": {
      "value": 8,
      "unit": "px",
      "type": "dimension",
      "description": "基础间距单位"
    },
    "scale": {
      "value": [4, 8, 12, 16, 24, 32, 48, 64, 80],
      "unit": "px",
      "type": "dimension",
      "description": "间距刻度列表"
    }
  },
  "typography": {
    "font-family": {
      "value": ["system-ui", "-apple-system", "BlinkMacSystemFont", "\"Segoe UI\"", "Roboto", "sans-serif"],
      "type": "fontFamily",
      "description": "系统字体栈，不加载 web 字体"
    },
    "font-size": {
      "h1": { "value": 40, "unit": "px", "type": "fontSize", "description": "页面主标题" },
      "h2": { "value": 32, "unit": "px", "type": "fontSize", "description": "板块标题" },
      "h3": { "value": 24, "unit": "px", "type": "fontSize", "description": "章节标题" },
      "h4": { "value": 20, "unit": "px", "type": "fontSize", "description": "小标题" },
      "body": { "value": 16, "unit": "px", "type": "fontSize", "description": "桌面基础正文" },
      "small": { "value": 14, "unit": "px", "type": "fontSize", "description": "移动端基础/辅助文字" },
      "mark": { "value": 12, "unit": "px", "type": "fontSize", "description": "标签、元数据" }
    },
    "line-height": {
      "heading": { "value": 1.25, "type": "lineHeight", "description": "标题行高" },
      "body": { "value": 1.5, "type": "lineHeight", "description": "正文行高" }
    },
    "font-weight": {
      "heading": { "value": "600", "type": "fontWeight", "description": "标题字重" },
      "body": { "value": "400", "type": "fontWeight", "description": "正文字重" }
    }
  },
  "border-radius": {
    "small": { "value": 4, "unit": "px", "type": "borderRadius", "description": "按钮、输入框" },
    "medium": { "value": 8, "unit": "px", "type": "borderRadius", "description": "卡片、模态框" },
    "large": { "value": 12, "unit": "px", "type": "borderRadius", "description": "弹窗大容器（上限）" }
  },
  "shadow": {
    "sm": {
      "value": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
      "type": "boxShadow",
      "description": "小阴影"
    },
    "md": {
      "value": "0 4px 6px -1px rgba(0, 0, 0, 0.05)",
      "type": "boxShadow",
      "description": "中阴影"
    }
  },
  "motion": {
    "duration": {
      "value": 300,
      "unit": "ms",
      "type": "duration",
      "description": "过渡时长上限"
    },
    "easing": {
      "value": "cubic-bezier(0.2, 0.9, 0.4, 1.1)",
      "type": "cubicBezier",
      "description": "缓动函数"
    }
  },
  "breakpoint": {
    "mobile": { "value": 640, "unit": "px", "type": "breakpoint", "description": "手机断点" },
    "tablet": { "value": 1024, "unit": "px", "type": "breakpoint", "description": "平板断点" }
  }
}